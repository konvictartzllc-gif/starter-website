{
        "buildCommand": "npm install && npm run build",
    "rewrites": [
          {
                  "source": "/api/:path*",
                  "destination": "https://konvict-artz.onrender.com/api/:path*"
          },
          {
                  "source": "/(.*)",
                  "destination": "/index.html"
          }
    ],
    "headers": [
          {
                  "source": "/(.*)",
                  "headers": [
                            {
                                        "key": "X-Content-Type-Options",
                                        "value": "nosniff"
                            },
                            {
                                        "key": "X-Frame-Options",
                                        "value": "DENY"
                            },
                            {
                                        "key": "X-XSS-Protection",
                                        "value": "1; mode=block"
                            }
                  ]
          }
    ]
}
