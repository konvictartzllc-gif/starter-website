{
  "buildCommand": "cd new code fixed/client && npm install && npm run build",
  "outputDirectory": "new code fixed/client/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://konvict-artz.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}