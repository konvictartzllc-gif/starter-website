# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
CLIENT_ORIGIN=https://www.konvict-artz.com

# ── Admin Credentials ─────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@konvict-artz.com
ADMIN_PASSWORD=YourSecurePasswordHere

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./data/konvict.db

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# ── Square ────────────────────────────────────────────────────────────────────
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_LOCATION_ID=your_square_location_id
SQUARE_ENV=production
DEX_PRICE_CENTS=999
DEX_CURRENCY=USD

# ── RingCentral ───────────────────────────────────────────────────────────────
RC_CLIENT_ID=your_ringcentral_client_id
RC_CLIENT_SECRET=your_ringcentral_client_secret
RC_USERNAME=your_ringcentral_main_number
RC_PASSWORD=your_ringcentral_password
RC_PHONE_NUMBER=+12055551234
RC_SERVER=https://platform.ringcentral.com
EMERGENCY_PHONE=2057492403
ADMIN_PHONE=2056239541

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SENDER_NAME=Konvict Artz
SENDER_EMAIL=noreply@konvict-artz.com
